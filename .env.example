PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=minuseek_dev
DB_USER=minuseek
DB_PASSWORD=change_me

DATABASE_URL=postgresql://minuseek:change_me@localhost:5432/minuseek_dev

ADMIN_DATABASE_URL=postgresql://minuseek:change_me@localhost:5432/minuseek_admin

# Template d'URL des bases tenant ({db} = database_name du registre)
TENANT_DATABASE_URL_TEMPLATE=postgresql://minuseek:change_me@localhost:5432/{db}

ORIGIN=http://localhost:5173

KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_INTERNAL_URL=http://localhost:8080
KEYCLOAK_AUDIENCE=minuseek-api
# Provisioning des organisations (Admin API Keycloak) : client confidentiel
# minuseek-provisioner sur le realm master — optionnel, l'API boote sans.
# KEYCLOAK_ADMIN_CLIENT_ID=minuseek-provisioner
# KEYCLOAK_ADMIN_CLIENT_SECRET=change_me
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change_me
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=change_me

# Stockage des images : bucket GCS de dev, URLs signées V4 keyless (ADR-0003).
# Setup une fois par poste (droits déjà accordés à l'équipe) :
#   gcloud auth application-default login \
#     --impersonate-service-account=back-runtime@dev-minuseek.iam.gserviceaccount.com
# Hors-ligne (aucune persistance) : STORAGE_DRIVER=in-memory
STORAGE_DRIVER=gcs
GCS_BUCKET=minuseek-media-dev
GCS_SIGNED_URL_TTL_SECONDS=900
