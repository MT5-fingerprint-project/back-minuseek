{
  "realm": "tenant-demo",
  "enabled": true,
  "displayName": "Minuseek — Tenant Demo",
  "loginTheme": "keycloak",
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Administrateur du tenant" },
      { "name": "investigator", "description": "Enquêteur" }
    ]
  },
  "clients": [
    {
      "clientId": "front-minuseek",
      "name": "Front Minuseek (SPA)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      },
      "protocolMappers": [
        {
          "name": "minuseek-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "minuseek-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "email": "demo@minuseek.local",
      "firstName": "Demo",
      "lastName": "Investigator",
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": ["investigator"]
    }
  ]
}
