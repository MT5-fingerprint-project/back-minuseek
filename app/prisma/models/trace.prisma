model Trace {
  id        String      @id @db.Uuid
  path      String
  status    TraceStatus @default(RECEIVED)
  score     Int?
  caseId    String      @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum TraceStatus {
  RECEIVED
  EXPLOITABLE
  NOT_EXPLOITABLE
}
