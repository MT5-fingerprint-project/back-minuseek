model User {
  id                 String       @id @default(uuid()) @db.Uuid
  identityProviderId String       @unique
  role               UserRole
  grade              String
  serviceNumber      String       @unique
  personalDataId     String       @unique @db.Uuid
  personalData       PersonalData @relation(fields: [personalDataId], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PersonalData {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String
  user      User?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  OPERATOR
  EXPERT
}

model Subject {
  id               String        @id @default(uuid()) @db.Uuid
  firstName        String
  lastName         String
  birthDate        DateTime      @db.Date
  birthPlace       String
  firstParentName  String?
  secondParentName String?
  phoneNumber      String?
  sex              Sex
  color            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  cases            SubjectCase[]
}

model SubjectCase {
  id        String      @id @default(uuid()) @db.Uuid
  subjectId String      @db.Uuid
  caseId    String      @db.Uuid
  type      SubjectType
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, caseId])
}

enum Sex {
  MALE
  FEMALE
}

enum SubjectType {
  KNOWN_ASSOCIATE
  SUSPECT
}
