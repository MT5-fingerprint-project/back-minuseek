model User {
  id                 String       @id @default(uuid()) @db.Uuid
  identityProviderId String       @unique
  role               UserRole
  grade              String
  serviceNumber      String       @unique
  personalDataId     String       @unique @db.Uuid
  personalData       PersonalData @relation(fields: [personalDataId], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PersonalData {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String
  user      User?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  OPERATOR
  EXPERT
}

model Subject {
  id               String      @id @default(uuid()) @db.Uuid
  firstName        String
  lastName         String
  birthDate        DateTime    @db.Date
  birthPlace       String
  firstParentName  String?
  secondParentName String?
  phoneNumber      String?
  sex              Sex
  type             SubjectType
  color            String?
  caseId           String      @db.Uuid
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([caseId])
}

enum Sex {
  MALE
  FEMALE
}

enum SubjectType {
  CLOSE_ASSOCIATE
  PERSON_OF_INTEREST
}
