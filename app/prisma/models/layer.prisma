model Layer {
  id            String   @id @default(uuid()) @db.Uuid
  fingerprintId String   @db.Uuid
  name          String   @db.VarChar(255)
  type          LayerType
  zIndex        Int
  isVisible     Boolean  @default(true)
  settings      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum LayerType {
  ANNOTATION
  FILTER
}
